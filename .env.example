# Flask API Configuration
# Copy this file to .env and update the values

# SECURITY - REQUIRED
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production

# Server Configuration
FLASK_ENV=development
HOST=0.0.0.0
PORT=5000

# File Upload Limits
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes

# Rate Limiting (requests per minute)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_ANALYSIS=10
RATE_LIMIT_DOWNLOAD=30
RATE_LIMIT_AUTH=20
RATE_LIMIT_ANALYTICS=100

# CORS Configuration
# Comma-separated list of allowed origins
# Use "*" for development, specific domains for production
ALLOWED_ORIGINS=*

# Database (optional - for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/football_ai

# Redis (optional - for Celery task queue)
# REDIS_URL=redis://localhost:6379/0

# Storage (optional - for S3/MinIO)
# S3_BUCKET=football-analysis
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT=https://s3.amazonaws.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=api_server.log

# JWT Configuration
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# Analysis Configuration
DEFAULT_ANALYSIS_LEVEL=3
OUTPUT_DIRECTORY=outputs
UPLOAD_DIRECTORY=uploads

# Model Configuration
MODEL_ID=uisikdag/yolo-v8-football-players-detection
CONFIDENCE_THRESHOLD=0.3
